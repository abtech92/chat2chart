# Copy this file to .env and fill in your values
# You only need ONE AI provider — pick whichever you prefer

# --- AI Providers (configure at least one) ---

# Google Gemini (FREE tier available — best for trials)
# Get key at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-key

# Ollama (FREE — runs locally on your machine)
# Install: https://ollama.ai then run: ollama pull llama3.1
# OLLAMA_URL=http://localhost:11434

# Anthropic Claude ($5 free credits on signup)
# Get key at: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI (pay-per-use)
# Get key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-xxxxx

# --- Databases (optional if using demo) ---

# PostgreSQL
# DATABASE_URL=postgresql://username:password@localhost:5432/your_database

# MySQL
# MYSQL_URL=mysql://username:password@localhost:3306/your_database

# Extra databases (JSON array)
# EXTRA_DATABASES=[{"key":"analytics","name":"Analytics DB","type":"postgres","url":"postgresql://..."}]

# Note: Run `python setup_demo_db.py` to create a free demo SQLite database
